# Firebase — copy to .env.local (never commit)
# Create project at https://console.firebase.google.com

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
FIREBASE_PROJECT_ID=lifequest-dev

# Flutter: run `flutterfire configure` after creating the Firebase project
# Functions secrets:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set ANTHROPIC_API_KEY
